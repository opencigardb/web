# Copy to .env.local and fill in. .env.local is gitignored.

# Signs the admin session cookie. Generate with:
#   openssl rand -base64 48
# Rotating this invalidates all existing admin sessions.
SESSION_SECRET=

# Base URL of the OCDB API, used by server components and route handlers.
API_URL=http://localhost:3001

# Shared secret proving admin write requests to the API came from this
# trusted server. Must match api/.env.local's ADMIN_API_TOKEN exactly.
ADMIN_API_TOKEN=
